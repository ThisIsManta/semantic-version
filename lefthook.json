{
	"pre-commit": {
		"commands": {
			"format": {
				"run": "npx --yes oxfmt {staged_files}",
				"stage_fixed": true
			},
			"test": {
				"run": "npm test --ci --silent"
			},
			"build": {
				"run": "npm run build"
			}
		}
	},
	"commit-msg": {
		"commands": {
			"lint": {
				"run": "node ./bin/lint-commit-message {1}"
			}
		}
	}
}
