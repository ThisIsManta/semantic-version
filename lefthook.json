{
	"post-checkout": {
		"commands": {
			"install": {
				"run": "npm install"
			}
		}
	},
	"pre-commit": {
		"commands": {
			"format": {
				"run": "npm exec oxfmt -- {staged_files}",
				"stage_fixed": true
			},
			"test": {
				"run": "npm test -- --no-watch"
			},
			"build": {
				"run": "npm run build"
			}
		}
	},
	"commit-msg": {
		"commands": {
			"lint": {
				"run": "node ./bin/lint-commit-message {1}"
			}
		}
	}
}
