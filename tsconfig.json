{
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"module": "CommonJS",
		"noUnusedLocals": true,
		"outDir": "../lib",
		"resolveJsonModule": true,
		"rootDir": "src",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2021",
		"types": ["node"]
	},
	"exclude": ["*.test.*"]
}
