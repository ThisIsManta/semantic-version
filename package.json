{
	"name": "@thisismanta/semantic-version",
	"version": "11.0.0",
	"license": "ISC",
	"author": "Anantachai Saothong <thisismanta@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ThisIsManta/semantic-version.git"
	},
	"bin": {
		"lint-commit-message": "bin/lint-commit-message",
		"make-next-release": "bin/make-next-release"
	},
	"files": [
		"lib",
		"bin"
	],
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"scripts": {
		"test": "vitest",
		"build": "rm -rf lib && tsc --outDir lib && find src -name '*.ts' ! -name '*.test.ts' | xargs npm exec rolldown -- --transform.target node22 --format commonjs --dir lib --chunk-file-names [name].js",
		"version": "npm run build",
		"postversion": "npm publish --provenance --access public"
	},
	"devDependencies": {
		"@actions/github": "^9.0.0",
		"@types/node": "~24.12.2",
		"@types/semver": "^7.7.1",
		"lefthook": "^2.1.5",
		"oxfmt": "^0.44.0",
		"semver": "^7.7.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"yn": "^5.1.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "npm",
			"version": "^11.9.0",
			"onFail": "error"
		},
		"runtime": {
			"name": "node",
			"version": "^24.14.0",
			"onFail": "warn"
		}
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
